# ═══════════════════════════════════════════════════════════════════════════
# NOVAGUARDIAN - Variables de Entorno (Ejemplo)
# Copia este archivo como .env y configura tus valores
# ═══════════════════════════════════════════════════════════════════════════

# Aplicación
APP_NAME=NovaGuardian
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Servidor
HOST=0.0.0.0
PORT=8000

# Base de datos PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/novaguardian
DATABASE_ECHO=False

# JWT
JWT_SECRET_KEY=tu_clave_secreta_muy_segura_cambiar_en_produccion_123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (para caché y WebSockets)
REDIS_URL=redis://localhost:6379/0

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","exp://localhost:8081"]

# Email (para recuperación de contraseña)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_de_app

# Twilio (SMS de emergencia - opcional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Configuración de alertas
ALERT_CHECK_INTERVAL_SECONDS=30
VITAL_SIGNS_RETENTION_DAYS=90
